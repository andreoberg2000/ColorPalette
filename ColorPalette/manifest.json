{
  "manifest_version": 3,
  "name": "Color Palette Extractor",
  "version": "1.1",
  "description": "Extract palette + pick any color with eyedropper",
  "icons": { 
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
   },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ]
}